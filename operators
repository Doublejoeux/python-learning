# arithmetic operators
x = 14
y = 3
print (x + y) # addition
print (x - y) # subtraction
print (x * y) # multiplication
print (x / y) # division
print (x // y) # floor division
print (x % y) # Modulus
print (x ** y) # Exponentiation

# comparison operators
a = 15
b = 15
print (a == b) # is a equal to b? - True
print (a != b) # is a not equal to b? - False
print (a > b) # is a greater than b? - False
print (a < b) # is a less than b? - False
print (a >= b) # is a greater than or equal to b? - True
print (a <= b) # is a less than or equal to b? - True

# assignment operators
score = 50 # output - 50
print (score)
score += 20 # output - 70
print (score)
score *= 2 # output - 140
print (score)
score -= 30 # output - 110
print (score)
score /= 2 # output - 55
print (score)