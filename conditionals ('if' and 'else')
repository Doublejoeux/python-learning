# conditionals (if/else)
score = 65
if score >= 90:
    print("Grade: A")
elif score >= 70:
    print("Grade: B")
elif score >= 50:
    print("Grade: C")
else:
    print("Grade: F")
# combining and/or
is_raining = True
has_umbrella = False
if is_raining and has_umbrella:
    print("You'll stay dry")
else:
    print("You might get wet")
